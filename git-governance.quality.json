{
  "schemaVersion": 2,
  "defaults": {
    "includeFamilies": [
      "feature",
      "fix",
      "docs",
      "refactor",
      "chore",
      "test",
      "perf",
      "hotfix"
    ]
  },
  "gates": [
    {
      "name": "unit-and-integration-tests",
      "command": "go",
      "args": [
        "test",
        "./..."
      ],
      "timeout": "2m"
    },
    {
      "name": "static-analysis",
      "command": "go",
      "args": [
        "vet",
        "./..."
      ],
      "timeout": "1m"
    },
    {
      "name": "complete-statement-coverage",
      "command": "go",
      "args": [
        "run",
        "./cmd/check-coverage"
      ],
      "timeout": "5m"
    }
  ]
}
