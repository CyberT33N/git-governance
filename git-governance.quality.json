{
  "schemaVersion": 2,
  "defaults": {
    "includeFamilies": [
      "feature",
      "fix",
      "docs",
      "refactor",
      "chore",
      "test",
      "perf",
      "hotfix"
    ]
  },
  "gates": [
    {
      "name": "full-local-build",
      "command": "go",
      "args": [
        "run",
        "-mod=readonly",
        "./cmd/build"
      ],
      "timeout": "15m"
    }
  ]
}
