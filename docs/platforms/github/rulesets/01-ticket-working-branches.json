{
  "name": "git-governance: official ticket and hotfix working branches",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/feature/*",
        "refs/heads/fix/*",
        "refs/heads/docs/*",
        "refs/heads/refactor/*",
        "refs/heads/chore/*",
        "refs/heads/test/*",
        "refs/heads/perf/*",
        "refs/heads/hotfix/*"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "non_fast_forward"
    }
  ]
}
